DASHSCOPE_API_KEY=
DASHSCOPE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_TIMEOUT_SECONDS=30
DASHSCOPE_TEMPERATURE=0.2
DASHSCOPE_MAX_TOKENS=512

RAG_DEFAULT_USER_ID=default_user
RAG_DEFAULT_WORKSPACE_ID=default_workspace
RAG_STORAGE_DIR=./data/rag_storage
RAG_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_tools
RAG_VECTOR_STORE_BACKEND=pgvector
RAG_FILE_STORAGE_BACKEND=local
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_DIM=128
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5

ANALYTICS_DATABASE_URL=
ANALYTICS_IP_SALT=change-me
