.page {
  padding: 24rpx;
  background: #f6f7f8;
  min-height: 100vh;
}

.header {
  margin-bottom: 18rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111;
}

.sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.textarea {
  width: 100%;
  min-height: 260rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f2f3f5;
  font-size: 28rpx;
  color: #111;
}

.btn {
  margin-top: 16rpx;
  border-radius: 14rpx;
}

.tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.block-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  color: #111;
}

.empty {
  font-size: 26rpx;
  color: #999;
}

.item {
  font-size: 28rpx;
  color: #222;
  margin: 8rpx 0;
  line-height: 1.5;
}

.reply {
  font-size: 28rpx;
  color: #222;
  line-height: 1.6;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f2f3f5;
}

.copyBtn {
  margin-top: 14rpx;
  border-radius: 14rpx;
}
