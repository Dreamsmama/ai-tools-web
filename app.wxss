page {
  background: #f7f7f7;
  color: #111;
  font-size: 16px;
}

.card {
  background: #fff;
  border-radius: 14px;
  padding: 14px;
  margin: 12px;
}

.h1 { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
.h2 { font-size: 16px; font-weight: 700; margin-bottom: 10px; }

.sub { color: #666; font-size: 13px; line-height: 1.6; }
.small { color: #777; font-size: 12px; line-height: 1.6; }

.btn {
  background: #111;
  color: #fff;
  border-radius: 12px;
  padding: 12px 14px;
  margin: 12px;
  text-align: center;
}

.btn.secondary {
  background: #fff;
  color: #111;
  border: 1px solid #ddd;
}

.field-label { font-weight: 700; margin-bottom: 8px; }
.textarea {
  width: 100%;
  min-height: 110px;
  box-sizing: border-box;
  background: #fafafa;
  border-radius: 12px;
  padding: 12px;
  border: 1px solid #eee;
}

.row {
  display: flex;
  gap: 10px;
}

.pill {
  display: inline-block;
  padding: 6px 10px;
  border-radius: 999px;
  background: #f1f1f1;
  font-size: 12px;
  color: #333;
  margin-right: 8px;
  margin-bottom: 8px;
}

.list-item {
  padding: 10px 0;
  border-bottom: 1px solid #eee;
}

.list-item:last-child { border-bottom: none; }

.disclaimer {
  margin: 10px 12px 16px;
  padding: 10px 12px;
  border-radius: 12px;
  background: #fff7e8;
  color: #7a4a00;
  font-size: 12px;
  line-height: 1.6;
  border: 1px solid #ffe2b8;
}

.copy {
  margin-top: 8px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 10px;
  padding: 10px 12px;
  text-align: center;
}

